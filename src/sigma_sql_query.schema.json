{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sigma_sql_query.schema.json",
  "title": "Constrained Sigma SQL Query Rule",
  "type": "object",
  "additionalProperties": false,
  "required": ["title", "logsource", "detection"],
  "properties": {
    "title": {
      "type": "string",
      "minLength": 1,
      "maxLength": 256
    },
    "id": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{8}-[0-9a-fA-F]{4}-[1-5][0-9a-fA-F]{3}-[89abAB][0-9a-fA-F]{3}-[0-9a-fA-F]{12}$"
    },
    "status": {
      "type": "string",
      "enum": ["experimental", "test", "stable", "deprecated"]
    },
    "description": {
      "type": "string"
    },
    "logsource": {
      "type": "object",
      "additionalProperties": false,
      "required": ["service"],
      "properties": {
        "category": {
          "type": "string"
        },
        "product": {
          "type": "string"
        },
        "service": {
          "type": "string",
          "minLength": 1,
          "description": "Logical table or business data source name."
        },
        "definition": {
          "type": "string"
        }
      }
    },
    "detection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["selection", "condition"],
      "properties": {
        "selection": {
          "type": "object",
          "minProperties": 1,
          "propertyNames": {
            "pattern": "^[A-Za-z_][A-Za-z0-9_]*(\\|(gte|lte|gt|lt|neq|contains|startswith|endswith|exists|cased|all|re|cidr))*$"
          },
          "additionalProperties": {
            "oneOf": [
              {
                "type": "string"
              },
              {
                "type": "number"
              },
              {
                "type": "boolean"
              },
              {
                "type": "array",
                "minItems": 1,
                "items": {
                  "oneOf": [
                    {
                      "type": "string"
                    },
                    {
                      "type": "number"
                    },
                    {
                      "type": "boolean"
                    }
                  ]
                }
              }
            ]
          }
        },
        "condition": {
          "type": "string",
          "const": "selection"
        }
      }
    },
    "fields": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      },
      "default": ["*"]
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  }
}
